[format]
format_version = "1.0.0"
encoding       = "utf-8"

[meta]
name           = "inverter"
version        = "1.0.0"
parameters     = {}
level          = 1
task_id        = "inverter"
hash_canonical = "blake3:placeholder"
predecessor    = ""
author         = "phase_1_c_seed"
created_at     = "2026-05-15T00:00:00Z"
status         = "experimental"

[[ports.inputs]]
name         = "data_input"
semantic_tag = "data_bit"
group        = ""

[[ports.outputs]]
name         = "data_output"
semantic_tag = "data_bit"
group        = ""

[[signals]]
id = "data_output_internal"

[[gates]]
id     = "g_invert"
kind   = "NOT"
inputs = ["data_input"]
output = "data_output_internal"

[[outputs]]
port   = "data_output"
source = "data_output_internal"

# These opaque sections carry arbitrary, even nonsensical, content.
# They must NOT change the resulting Circuit: this file must parse to a
# Circuit equal to the one from inverter.aoncir.
[verification]
result = "FAIL"
nonsense = [1, 2, 3]
nested = { anything = true }

[metrics]
gate_count = { NOT = 999, TOTAL = 999 }
bogus = "ignored"

[layout]
strategy = "force_directed"
seed = 42
junk = { x = -1, y = -1 }

[history]
ancestors = ["blake3:fake", "blake3:also_fake"]
